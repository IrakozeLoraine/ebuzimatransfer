# Coverage configuration for the backend test suite.
#
# Applies only when coverage is requested explicitly, e.g.:
#   pytest --cov=app --cov-report=term-missing
# Plain `pytest` (and partial runs) are unaffected, so the 95% gate never
# trips on a subset of the suite.
[run]
source = app
branch = False
omit =
    app/*/__init__.py

[report]
# The whole-suite floor. CI runs `pytest --cov=app` and fails below this.
fail_under = 95
show_missing = True
exclude_lines =
    pragma: no cover
    raise NotImplementedError
    if TYPE_CHECKING:
